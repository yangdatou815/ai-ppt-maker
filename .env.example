# ===== ai-ppt-maker .env =====
# Backend
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
# Per-logger overrides; comma-separated `name=LEVEL`. Useful for targeted debug:
#   LOG_LEVEL=INFO LOG_LEVEL_OVERRIDES=app.outline=DEBUG,httpx=WARNING
LOG_LEVEL_OVERRIDES=

# Ollama (本地)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_S=120

# Workspace / 临时文件
WORKSPACE_DIR=/tmp/ai-ppt-maker
WORKSPACE_TTL_HOURS=24

# LibreOffice (容器内)
LIBREOFFICE_BIN=/usr/bin/soffice

# Limits
MAX_UPLOAD_MB=50

# Frontend
VITE_API_BASE=/api
